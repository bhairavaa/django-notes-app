# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Python / Django ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
env/
venv/
.venv/
ENV/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/
mediafiles/
media/

# Django migrations (keep initial, ignore if preferred)
# */migrations/*.py  # uncomment to ignore all migrations

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# ─── Environment variables ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Node / React ─────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.js

# Testing
/coverage

# Production build
mynotes/build/

# Misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ─── Docker ───────────────────────────────────────────────────────────────────
.dockerignore

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
